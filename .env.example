ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE_EXTRACTION=0.0
CLAUDE_TEMPERATURE_ANALYSIS=0.1
CLAUDE_TEMPERATURE_CONVERSATION=0.2
CLAUDE_TEMPERATURE_SYNTHESIS=0.3

# Notion MCP — dejar vacío para usar demo JSON
NOTION_API_KEY=
NOTION_POLICIES_DB_ID=

# PostgreSQL
DATABASE_URL=postgresql://copago_user:changeme_in_prod@postgres:5432/copago
POSTGRES_PASSWORD=changeme_in_prod

# Redis
REDIS_URL=redis://:changeme_in_prod@redis:6379/0
REDIS_PASSWORD=changeme_in_prod

# Cifrado LOPDP — generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=GENERAR_CON_COMANDO_ARRIBA

# LOPDP / Cumplimiento
CONSENT_VERSION=1.0
DATA_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=2555
DPO_EMAIL=privacidad@copayai.ec
CONTROLLER_NAME=CopayAI — hackIAthon Viamatica
CONTROLLER_RUC=0000000000001

# JWT Auth — generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERAR_CON_COMANDO_ARRIBA_32_CHARS_MINIMO
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# Twilio WhatsApp — https://console.twilio.com (dejar vacío para modo demo/log)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Webhook secret — generar con: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# ── SMTP Email (notificaciones ARCO, recordatorios, alertas DPO) ─────────────
# Gmail: smtp.gmail.com:587 | SendGrid: smtp.sendgrid.net:587 | dejar vacío → demo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM_EMAIL=no-reply@copayai.ec
SMTP_FROM_NAME=CopayAI Ecuador

# ── HL7 FHIR R4 (interoperabilidad HIS hospitalario) ────────────────────────
# Dejar vacío → datos demo en formato FHIR
FHIR_BASE_URL=
FHIR_TOKEN=

# ── IESS Ecuador (verificación afiliación) ───────────────────────────────────
# Requiere convenio interinstitucional con el IESS
IESS_API_URL=
IESS_API_KEY=

# ── Kushki (cobro digital de copagos) ────────────────────────────────────────
# Obtener en: https://dashboard.kushkipagos.com | dejar vacío → modo demo
KUSHKI_PUBLIC_KEY=
KUSHKI_PRIVATE_KEY=
KUSHKI_SANDBOX=true

# ── Aseguradoras (consulta de pólizas en tiempo real) ────────────────────────
# Cada aseguradora requiere convenio de interoperabilidad
ASEG_BMI_API_KEY=
ASEG_BMI_API_URL=https://api.bmigrupo.com/ec/v1
ASEG_ECUASANITAS_API_KEY=
ASEG_ECUASANITAS_API_URL=https://api.ecuasanitas.com/v2
ASEG_MAPFRE_API_KEY=
ASEG_MAPFRE_API_URL=https://api.mapfre.com.ec/ws

# ── DINARDAP (verificación identidad ciudadana) ──────────────────────────────
# Requiere convenio con Registro Civil / DINARDAP
